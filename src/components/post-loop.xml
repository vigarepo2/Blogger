<div class='grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8'>
  <b:loop values='data:posts' var='post'>
    <article class='group flex flex-col bg-white rounded-2xl border border-gray-100 overflow-hidden hover:shadow-xl hover:shadow-gray-200/50 transition-all duration-300'>
      
      <a expr:href='data:post.url' class='aspect-video overflow-hidden bg-gray-50'>
        <b:if cond='data:post.featuredImage'>
          <img class='w-full h-full object-cover group-hover:scale-105 transition-transform duration-500' expr:src='data:post.featuredImage' />
        <b:else/>
          <div class='w-full h-full flex items-center justify-center text-gray-300'>
            <svg class='w-12 h-12' fill='none' stroke='currentColor' viewBox='0 0 24 24'><path d='M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z' stroke-linecap='round' stroke-linejoin='round' stroke-width='1'/></svg>
          </div>
        </b:if>
      </a>

      <div class='p-6 flex flex-col flex-grow'>
        <div class='flex items-center space-x-2 text-xs font-medium text-blue-600 mb-3 uppercase tracking-wider'>
          <b:if cond='data:post.labels'>
            <data:post.labels.first.name/>
          </b:if>
        </div>
        
        <h2 class='text-xl font-semibold leading-tight mb-3 group-hover:text-blue-600 transition-colors'>
          <a expr:href='data:post.url'><data:post.title/></a>
        </h2>
        
        <p class='text-gray-500 text-sm line-clamp-3 mb-6'>
          <data:post.snippet/>
        </p>

        <div class='mt-auto pt-4 border-t border-gray-50 flex items-center justify-between text-xs text-gray-400'>
          <span><data:post.date/></span>
          <span class='flex items-center'>
            <svg class='w-3 h-3 mr-1' fill='none' stroke='currentColor' viewBox='0 0 24 24'><path d='M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z' stroke-linecap='round' stroke-linejoin='round' stroke-width='2'/></svg>
            <data:post.author.name/>
          </span>
        </div>
      </div>
    </article>
  </b:loop>
</div>
